# Copier ce fichier en `.env` et générer de vraies valeurs (ne jamais committer `.env`).

# Secret de scellement des sessions cookie (nuxt-auth-utils / h3).
# Minimum 32 caractères. Générer avec : openssl rand -hex 32
NUXT_SESSION_PASSWORD=change-me-to-a-random-string-of-at-least-32-characters

# Clé de chiffrement au repos des secrets applicatifs (connecteurs JIRA/LLM, phase 4).
# Générer avec : openssl rand -hex 32
NUXT_APP_SECRET=change-me-to-a-random-string-of-at-least-32-characters
